{
  "name": "agent-context",
  "version": "0.1.0",
  "description": "Obsidian plugin that records workspace state (open tabs, active file, selection) to a local JSON file",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npx tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "obsidian"
  ],
  "author": "xuezhaojun",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
